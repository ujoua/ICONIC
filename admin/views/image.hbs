<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>App</title>
    <style>
      img {
        width: 400px;
      }
    </style>
  </head>
  <body>
    <h1>이미지 상세</h1>
    <p><strong>{{image.title}}</strong> - {{image.text}}</p>
    <img src="../img/{{image.filePath}}"></img>

    <hr />

    <h2>정보 수정</h2>
    <form id="editForm">
      <div>
        <label for="artist">작가:</label>
        <input type="text" id="artist" name="artist" value="{{image.artist}}" />
      </div>

      <div>
        <label for="title">제목:</label>
        <input type="text" id="title" name="title" value="{{image.title}}" />
      </div>

      <div>
        <label for="text">설명:</label>
        <input type="text" id="text" name="text" value="{{image.text}}" />
      </div>

      <div>
        <label for="tags">태그 (쉼표로 구분):</label>
        <input
          type="text"
          id="tags"
          name="tags"
          value="{{image.tags}}"
          placeholder="예: landscape,snow"
        />
      </div>

      <div>
        <label for="earliestDate">촬영일(earliestDate):</label>
        <input
          type="date"
          id="earliestDate"
          name="earliestDate"
          value="{{image.earliestDate}}"
        />
      </div>

      <div>
        <label for="camera">카메라:</label>
        <input
          type="text"
          id="camera"
          name="camera"
          value="{{image.camera}}"
        />
      </div>

      <div>
        <label for="materials">재료/세부정보 (쉼표로 구분):</label>
        <input
          type="text"
          id="materials"
          name="materials"
          value="{{image.materials}}"
          placeholder="예: 54mm,F4.3,1/100s,ISO400,0.0ev"
        />
      </div>

      <div>
        <label for="dimensons">크기 (dimensons):</label>
        <input
          type="text"
          id="dimensons"
          name="dimensons"
          value="{{image.dimensons}}"
          placeholder="예: 1280 x 1920"
        />
      </div>

      <button type="submit">수정 저장</button>
    </form>

    <hr />
    <button id="deleteBtn" type="button">삭제</button>

    <script>
      (function () {
        const form = document.getElementById('editForm');
        const deleteBtn = document.getElementById('deleteBtn');
        const filePath = '{{image.filePath}}';

        form.addEventListener('submit', async function (e) {
          e.preventDefault();

          const formData = new URLSearchParams();
          const fields = [
            'artist',
            'title',
            'text',
            'tags',
            'earliestDate',
            'camera',
            'materials',
            'dimensons',
          ];

          fields.forEach((name) => {
            const input = document.getElementById(name);
            if (input && input.value !== '') {
              formData.append(name, input.value);
            }
          });

          try {
            const res = await fetch('/images/{{image.filePath}}', {
              method: 'PATCH',
              headers: {
                'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
              },
              body: formData.toString(),
            });

            if (!res.ok) {
              const text = await res.text();
              alert('수정에 실패했습니다: ' + text);
              return;
            }

            alert('수정이 저장되었습니다.');
            window.location.reload();
          } catch (err) {
            console.error(err);
            alert('요청 중 오류가 발생했습니다.');
          }
        });

        deleteBtn.addEventListener('click', async function () {
          const ok = confirm('정말 이 이미지를 삭제할까요?');
          if (!ok) return;

          try {
            const res = await fetch('/images/' + encodeURIComponent(filePath), {
              method: 'DELETE',
            });

            if (!res.ok) {
              const text = await res.text();
              alert('삭제에 실패했습니다: ' + text);
              return;
            }

            alert('삭제되었습니다.');
            window.location.href = '/images';
          } catch (err) {
            console.error(err);
            alert('요청 중 오류가 발생했습니다.');
          }
        });
      })();
    </script>
  </body>
</html>